ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://user:password@host:5432/dbname
GITHUB_TOKEN=
POLL_INTERVAL_MS=3000
MAX_CONCURRENT_AGENTS=5
MAX_ATTEMPTS=5
MAX_RETRY_BACKOFF_MS=300000
MAX_TURNS=10
MAX_STALL_MS=3600000
CLI_ATTACH_COMMAND_TEMPLATE=ant sessions connect {session_id}

# Skip GitHub OAuth when developing locally — set to false for prod-like auth testing
DEV_AUTH_BYPASS=true

# Explicit base URL — leave unset locally (Auth.js infers from localhost).
# Production: set to your canonical domain, e.g. https://app.example.com
# Vercel Preview: set to the branch alias URL so GitHub OAuth redirects back correctly.
#   In Vercel project settings → Environment Variables, scope this to Preview and
#   set it to https://<project>-git-<branch>-<org>.vercel.app
#   Use a separate GitHub OAuth App for preview (see ADR-008).
AUTH_URL=

# GitHub OAuth (create app at https://github.com/settings/applications/new)
# For Vercel Preview environments, create a second OAuth App with the preview
# callback URL and set GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET per environment
# in Vercel project settings.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Comma-separated GitHub usernames allowed to access the app
# Empty or unset = startup failure (fail-closed)
ALLOWED_GITHUB_USERS=user1,user2
