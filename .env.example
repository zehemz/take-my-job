ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://user:password@host:5432/dbname
GITHUB_TOKEN=
POLL_INTERVAL_MS=3000
MAX_CONCURRENT_AGENTS=5
MAX_ATTEMPTS=5
MAX_RETRY_BACKOFF_MS=300000
MAX_TURNS=10
MAX_STALL_MS=3600000
CLI_ATTACH_COMMAND_TEMPLATE=ant sessions connect {session_id}

# Skip GitHub OAuth when developing locally — set to false for prod-like auth testing
DEV_AUTH_BYPASS=true

# GitHub OAuth (create app at https://github.com/settings/applications/new)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# Comma-separated GitHub usernames allowed to access the app
# Empty or unset = startup failure (fail-closed)
ALLOWED_GITHUB_USERS=user1,user2
