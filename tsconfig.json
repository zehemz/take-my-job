{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": ["lib", "scripts", "tests"],
  "exclude": ["lib/db.ts", "lib/db-queries.ts", "scripts/setup-agents.ts", "prisma", "lib/__tests__"]
}
